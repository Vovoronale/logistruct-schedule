{
  "name": "logistruct-schedule",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:cf": "npm run build && wrangler pages dev dist",
    "dev:test": "npm run build && wrangler pages dev dist --ip 127.0.0.1 --port 8788 --persist-to .wrangler/test-state",
    "build": "npm run typecheck && vite build",
    "typecheck": "tsc -b && tsc -p functions/tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "db:test:reset": "node scripts/test-db.mjs reset",
    "db:test:seed": "node scripts/test-db.mjs seed",
    "cf-typegen": "wrangler types --path functions/types.d.ts",
    "deploy": "npm run build && wrangler pages deploy dist --project-name logistruct-schedule"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260702.1",
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^8.1.3",
    "vitest": "^4.1.9",
    "wrangler": "^4.107.0"
  }
}
